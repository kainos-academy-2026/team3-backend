{
	"name": "team3-backend",
	"version": "1.0.0",
	"description": "Team3 Backend",
	"type": "module",
	"main": "dist/index.js",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"check": "biome check --write .",
		"ci:check": "biome ci .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:ui": "vitest --ui",
		"db:up": "docker compose up -d",
		"db:down": "docker compose down",
		"prisma:migrate": "prisma migrate dev --name init",
		"prisma:seed": "prisma db seed",
		"prisma:studio": "prisma studio"
	},
	"vitest": {
		"environment": "node"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kainos-academy-2026/team3-backend.git"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/kainos-academy-2026/team3-backend/issues"
	},
	"homepage": "https://github.com/kainos-academy-2026/team3-backend#readme",
	"dependencies": {
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"express": "^5.2.1",
		"pg": "^8.22.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@types/express": "^5.0.6",
		"@types/supertest": "^7.2.0",
		"@vitest/coverage-v8": "^4.1.10",
		"@vitest/ui": "^4.1.10",
		"prisma": "^7.8.0",
		"supertest": "^7.2.2",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.10"
	}
}
